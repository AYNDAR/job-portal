generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== USER & ROLE TABLES ====================

model UserType {
  id        Int     @id @default(autoincrement())
  type_name String  @unique
  users     User[]
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String
  user_type_id Int
  user_type   UserType @relation(fields: [user_type_id], references: [id])
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  job_seeker_profile JobSeekerProfile?
  employer_profile   EmployerProfile?
  notifications      Notification[]
}

model JobSeekerProfile {
  id         String   @id @default(uuid())
  user_id    String   @unique
  user       User     @relation(fields: [user_id], references: [id])
  full_name  String
  phone      String?
  resume_url String?
  skills     String[]
  location   String?

  applications JobApplication[]
  bookmarks    JobBookmark[]
}

model EmployerProfile {
  id           String   @id @default(uuid())
  user_id      String   @unique
  user         User     @relation(fields: [user_id], references: [id])
  company_name String
  website      String?
  logo_url     String?
  industry_id  Int
  industry     JobIndustry @relation(fields: [industry_id], references: [id])
  location     String?

  jobs              JobPost[]
  application_notes JobApplicationNote[]
}

// ==================== JOB & LOOKUP TABLES ====================

model JobIndustry {
  id           Int     @id @default(autoincrement())
  industry_name String @unique
  employers     EmployerProfile[]
  jobs          JobPost[]
}

model EmploymentType {
  id        Int     @id @default(autoincrement())
  type_name String  @unique
  jobs      JobPost[]
}

model JobPostStatus {
  id          Int     @id @default(autoincrement())
  status_name String  @unique
  jobs        JobPost[]
}

model JobPost {
  id                 String   @id @default(uuid())
  title              String
  description        String
  employer_id        String
  employer           EmployerProfile @relation(fields: [employer_id], references: [id])
  industry_id        Int
  industry           JobIndustry @relation(fields: [industry_id], references: [id])
  employment_type_id Int
  employment_type    EmploymentType @relation(fields: [employment_type_id], references: [id])
  salary_range       String?
  status_id          Int
  status             JobPostStatus @relation(fields: [status_id], references: [id])
  created_at         DateTime @default(now())

  jobSite          String?
  experienceLevel  String?
  educationLevel   String?
  genderPreference String?

  requirements        String?
  application_deadline DateTime?
  show_salary         Boolean   @default(true)
  highlight_job       Boolean   @default(false)
  allow_remote        Boolean   @default(false)
  budget_type         String?
  budget_min          Float?
  budget_max          Float?
  duration            String?
  experience_level    String?
  skills              String[]
  require_resume      Boolean   @default(false)
  attachments         String[]

  applications JobApplication[]
  bookmarks    JobBookmark[]
}

model JobApplicationStatus {
  id          Int     @id @default(autoincrement())
  status_name String  @unique
  applications JobApplication[]
}

model JobApplication {
  id           String   @id @default(uuid())
  job_id       String
  job          JobPost  @relation(fields: [job_id], references: [id])
  seeker_id    String
  seeker       JobSeekerProfile @relation(fields: [seeker_id], references: [id])
  resume_url   String?
  cover_letter String?
  status_id    Int
  status       JobApplicationStatus @relation(fields: [status_id], references: [id])
  applied_at   DateTime @default(now())

  notes JobApplicationNote[]
}

model JobApplicationNote {
  id             Int      @id @default(autoincrement())
  application_id String
  application    JobApplication @relation(fields: [application_id], references: [id])
  employer_id    String
  employer       EmployerProfile @relation(fields: [employer_id], references: [id])
  note_text      String
  created_at     DateTime @default(now())
}

model JobBookmark {
  id         Int    @id @default(autoincrement())
  seeker_id  String
  seeker     JobSeekerProfile @relation(fields: [seeker_id], references: [id])
  job_id     String
  job        JobPost @relation(fields: [job_id], references: [id])
  created_at DateTime @default(now())

  @@unique([seeker_id, job_id])
}

model Notification {
  id           Int      @id @default(autoincrement())
  user_id      String
  user         User     @relation(fields: [user_id], references: [id])
  message      String
  trigger_type String
  is_read      Boolean  @default(false)
  created_at   DateTime @default(now())
}

model SearchLog {
  id         Int      @id @default(autoincrement())
  user_id    String?
  query_text String
  filters    Json?
  created_at DateTime @default(now())
}